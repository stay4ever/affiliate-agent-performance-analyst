# ──────────────────────────────────────────────────────────────────────────────
# affiliate-agent-performance-analyst — Environment Variables
#
# Copy this file to .env and fill in your values.
# .env is git-ignored and should NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenAI API key — obtain from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Optional — Agent behaviour ────────────────────────────────────────────────

# LLM model used for analysis (default: gpt-4o)
# Supported values: gpt-4o, gpt-4o-mini, gpt-4-turbo
OPENAI_MODEL=gpt-4o

# Maximum spend per agent run in USD (no limit if unset)
# MAX_BUDGET_USD=1.00

# ── Optional — Output ─────────────────────────────────────────────────────────

# Directory where performance_report.json is written (default: ./output)
OUTPUT_DIR=./output

# ── Optional — Security ──────────────────────────────────────────────────────

# Base directory that data_file arguments must reside within (default: cwd)
# DATA_BASE_DIR=/app/data

# Base directory that output_dir must reside within (default: cwd)
# OUTPUT_BASE_DIR=/app/output

# Comma-separated allowlist of hostnames permitted for CALLBACK_URL (agent.py).
# When set, only these hosts can receive callback POSTs.
# ALLOWED_CALLBACK_HOSTS=api.nanoplasticity.io,hooks.example.com

# ── Optional — Observability ──────────────────────────────────────────────────

# Logging verbosity: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO
